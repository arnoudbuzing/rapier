Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Existing", " ", "floor", " ", "setup"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"floorId", "=", 
     RowBox[{"RapierAddRigidBody", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"{", 
        RowBox[{"0.0", ",", "0.0", ",", 
         RowBox[{"-", "1.0"}]}], "}"}], ",", "\"\<Fixed\>\""}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"RapierAddColliderCuboid", "[", 
     RowBox[{"worldId", ",", "floorId", ",", 
      RowBox[{"{", 
       RowBox[{"10.0", ",", "10.0", ",", "1.0"}], "}"}], ",", "1.0"}], "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Set", " ", "the", " ", "desired", " ", "wall", " ", "height"}], 
    "*)"}], 
   RowBox[{
    RowBox[{"wallHeight", "=", "5.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wallZCenter", "=", 
     RowBox[{"wallHeight", "/", "2.0"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"The", " ", "center", " ", "position", " ", "in", " ", "Z"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"wallZExtent", "=", 
     RowBox[{"wallHeight", "/", "2.0"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"The", " ", "half"}], "-", 
     RowBox[{"extent", " ", "in", " ", "Z"}]}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Wall", " ", 
     RowBox[{"configurations", ":", 
      RowBox[{"{", 
       RowBox[{"position", ",", 
        RowBox[{"half", "-", "extents"}]}], "}"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wallConfigs", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"10.5", ",", "0.0", ",", "wallZCenter"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.5", ",", "10.0", ",", "wallZExtent"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"X", "+"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10.5"}], ",", "0.0", ",", "wallZCenter"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.5", ",", "10.0", ",", "wallZExtent"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"X", "-"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.0", ",", "10.5", ",", "wallZCenter"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"11.0", ",", "0.5", ",", "wallZExtent"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"Y", "+"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.0", ",", 
           RowBox[{"-", "10.5"}], ",", "wallZCenter"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"11.0", ",", "0.5", ",", "wallZExtent"}], "}"}]}], "}"}]}], 
      "  ", 
      RowBox[{"(*", 
       RowBox[{"Y", "-"}], "*)"}], "}"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Add", " ", "each", " ", "wall", " ", "to", " ", "the", " ", "world"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "wallId", "}"}], ",", 
       RowBox[{
        RowBox[{"wallId", "=", 
         RowBox[{"RapierAddRigidBody", "[", 
          RowBox[{"worldId", ",", 
           RowBox[{"config", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<Fixed\>\""}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"RapierAddColliderCuboid", "[", 
         RowBox[{"worldId", ",", "wallId", ",", 
          RowBox[{"config", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", "1.0"}], "]"}]}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"config", ",", "wallConfigs"}], "}"}]}], "]"}], 
   "\n"}]}]], "Input",
