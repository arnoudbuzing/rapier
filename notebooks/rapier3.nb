                    RowBox[{
                    RowBox[{"5", "+", "i"}], ",", 
                    RowBox[{"2", ";;", "4"}]}], "]"}], "]"}]}], "}"}]}], 
                  "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i", ",", "75"}], "}"}]}], "]"}]}], "}"}], ",", 
             RowBox[{"(*", 
