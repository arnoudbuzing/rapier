                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"quatToMatrix", "[", 
                    RowBox[{"bodies", "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{"5", "+", "i"}], ",", 
                    RowBox[{"5", ";;", "8"}]}], "]"}], "]"}], "]"}], ",", 
                    RowBox[{"bodies", "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{"5", "+", "i"}], ",", 
                    RowBox[{"2", ";;", "4"}]}], "]"}], "]"}]}], "}"}]}], 
                   "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", "75"}], "}"}]}], "]"}]}], "}"}]}], "}"}],
             ",", 
            RowBox[{"PlotRange", "->", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "12"}], ",", "12"}], "}"}], ",", 
