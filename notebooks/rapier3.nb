         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", " ", "qy"}], "-", 
            RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", " ", "qz"}], "+", 
            RowBox[{"qw", " ", "qy"}]}], ")"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", " ", "qy"}], "+", 
            RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
         RowBox[{"1", "-", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", "^", "2"}], "+", 
             RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qy", " ", "qz"}], "-", 
            RowBox[{"qw", " ", "qx"}]}], ")"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", " ", "qz"}], "-", 
            RowBox[{"qw", " ", "qy"}]}], ")"}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qy", " ", "qz"}], "+", 
            RowBox[{"qw", " ", "qx"}]}], ")"}]}], ",", 
         RowBox[{"1", "-", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", "^", "2"}], "+", 
             RowBox[{"qy", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "}"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"1.", " ", "Setup", " ", "Simulation"}], "*)"}], 
    RowBox[{"worldId", "=", 
     RowBox[{"RapierWorldCreate", "[", 
      RowBox[{"{", 
       RowBox[{"0.", ",", "0.", ",", 
        RowBox[{"-", "9.81"}]}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"Fixed", " ", "floor"}], "*)"}], 
    RowBox[{"floorId", "=", 
     RowBox[{"RapierAddRigidBody", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"{", 
        RowBox[{"0.", ",", "0.", ",", 
         RowBox[{"-", "0.1"}]}], "}"}], ",", "\"\<Fixed\>\""}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"RapierAddColliderCuboid", "[", 
     RowBox[{"worldId", ",", "floorId", ",", 
      RowBox[{"{", 
       RowBox[{"10.", ",", "10.", ",", "0.1"}], "}"}], ",", "1.0"}], "]"}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"(*", 
