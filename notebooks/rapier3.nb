   RowBox[{"{", 
    RowBox[{
    "worldId", ",", "floorId", ",", "cuboidIds", ",", "ballId", ",", "bodies",
      ",", 
     RowBox[{"step", "=", "0"}], ",", "initialQuat", ",", "quatToMatrix", ",",
      "frame"}], "}"}], ",", 
   RowBox[{"(*", 
    RowBox[{"Helper", ":", 
     RowBox[{"Convert", " ", "Rapier", " ", 
      RowBox[{"{", 
       RowBox[{"qx", ",", "qy", ",", "qz", ",", "qw"}], "}"}], " ", "to", " ",
       "Rotation", " ", "Matrix"}]}], "*)"}], 
   RowBox[{
    RowBox[{
     RowBox[{"quatToMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"qx_", ",", "qy_", ",", "qz_", ",", "qw_"}], "}"}], "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
