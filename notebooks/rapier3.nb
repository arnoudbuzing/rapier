Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "worldId", ",", "floorId", ",", "cuboidIds", ",", "bodies", ",", 
      "initialQuats", ",", "quatToMatrix", ",", "frame"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{"Helper", ":", 
      RowBox[{"Convert", " ", "Rapier", " ", 
       RowBox[{"{", 
        RowBox[{"qx", ",", "qy", ",", "qz", ",", "qw"}], "}"}], " ", "to", " ",
        "Rotation", " ", "Matrix"}]}], "*)"}], 
    RowBox[{
     RowBox[{
      RowBox[{"quatToMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"qx_", ",", "qy_", ",", "qz_", ",", "qw_"}], "}"}], "]"}], ":=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "-", 
           RowBox[{"2", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"qy", "^", "2"}], "+", 
              RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", " ", "qy"}], "-", 
             RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", " ", "qz"}], "+", 
             RowBox[{"qw", " ", "qy"}]}], ")"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", " ", "qy"}], "+", 
             RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
          RowBox[{"1", "-", 
           RowBox[{"2", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"qx", "^", "2"}], "+", 
              RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qy", " ", "qz"}], "-", 
             RowBox[{"qw", " ", "qx"}]}], ")"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", " ", "qz"}], "-", 
             RowBox[{"qw", " ", "qy"}]}], ")"}]}], ",", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qy", " ", "qz"}], "+", 
             RowBox[{"qw", " ", "qx"}]}], ")"}]}], ",", 
          RowBox[{"1", "-", 
           RowBox[{"2", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"qx", "^", "2"}], "+", 
              RowBox[{"qy", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"1.", " ", "Setup", " ", "Simulation"}], "*)"}], 
     RowBox[{"worldId", "=", 
      RowBox[{"RapierWorldCreate", "[", 
       RowBox[{"{", 
        RowBox[{"0.", ",", "0.", ",", 
         RowBox[{"-", "9.81"}]}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"(*", 
      RowBox[{"Fixed", " ", "floor"}], "*)"}], 
     RowBox[{"floorId", "=", 
      RowBox[{"RapierAddRigidBody", "[", 
       RowBox[{"worldId", ",", 
        RowBox[{"{", 
         RowBox[{"0.", ",", "0.", ",", 
          RowBox[{"-", "0.1"}]}], "}"}], ",", "\"\<Fixed\>\""}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", "floorId", ",", 
       RowBox[{"{", 
        RowBox[{"10.", ",", "10.", ",", "0.1"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Invisible", " ", "Barriers", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"X", "+"}], ",", 
         RowBox[{"X", "-"}], ",", 
         RowBox[{"Y", "+"}], ",", 
         RowBox[{"Y", "-"}]}], ")"}]}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{
      "Positioned", " ", "just", " ", "outside", " ", "the", " ", "10", "x10",
        " ", "area", " ", "with", " ", "a", " ", "height", " ", "of", " ", 
       "10"}], "*)"}], 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"10.1", ",", "0", ",", "5"}], "}"}], ",", "\"\<Fixed\>\""}],
         "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"0.1", ",", "10", ",", "5"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10.1"}], ",", "0", ",", "5"}], "}"}], 
         ",", "\"\<Fixed\>\""}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"0.1", ",", "10", ",", "5"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "10.1", ",", "5"}], "}"}], ",", "\"\<Fixed\>\""}],
         "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "0.1", ",", "5"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"-", "10.1"}], ",", "5"}], "}"}], ",", "\"\<Fixed\>\""}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "0.1", ",", "5"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"2.", " ", "Create", " ", "3", " ", "Dynamic", " ", "Cuboids"}],
       "*)"}], 
     RowBox[{"cuboidIds", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"initialQuats", "[", "i", "]"}], "=", 
          RowBox[{"Normalize", "[", 
           RowBox[{"RandomReal", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "4"}], "]"}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"RapierAddColliderCuboid", "[", 
          RowBox[{"worldId", ",", 
           RowBox[{"RapierAddRigidBody", "[", 
            RowBox[{"worldId", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"RandomReal", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "5"}], ",", "5"}], "}"}], "]"}], ",", 
               RowBox[{"RandomReal", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "5"}], ",", "5"}], "}"}], "]"}], ",", 
               RowBox[{"4.0", "*", "i"}]}], "}"}], ",", 
             RowBox[{"initialQuats", "[", "i", "]"}], 
             ",", "\"\<Dynamic\>\""}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"1.0", ",", "1.0", ",", "1.0"}], "}"}], ",", "1.0"}], 
          "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "3"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"FrameListVideo", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"bodies", "=", 
          RowBox[{"RapierGetBodyPositions", "[", "worldId", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"frame", "=", 
          RowBox[{"Graphics3D", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"(*", 
              RowBox[{"Red", " ", "floor", " ", "visual"}], "*)"}], 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"Red", ",", 
                RowBox[{"Opacity", "[", "0.6", "]"}], ",", 
                RowBox[{"Specularity", "[", 
                 RowBox[{"White", ",", "10"}], "]"}], ",", 
                RowBox[{"Cuboid", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"-", "10"}], ",", 
                    RowBox[{"-", "10"}], ",", 
                    RowBox[{"-", "0.2"}]}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"10", ",", "10", ",", "0"}], "}"}]}], "]"}]}], 
               "}"}], ",", 
              RowBox[{"(*", 
               RowBox[{"White", " ", "cubes", " ", 
                RowBox[{"(", 
                 RowBox[{
                 "The", " ", "barriers", " ", "are", " ", "NOT", " ", 
                  "rendered", " ", "here"}], ")"}]}], "*)"}], 
              RowBox[{"{", 
               RowBox[{"White", ",", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"GeometricTransformation", "[", 
                   RowBox[{
                    RowBox[{"Cuboid", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", 
                    RowBox[{"-", "1"}], ",", 
                    RowBox[{"-", "1"}]}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], "]"}], ",", 
                    RowBox[{"(*", 
                    RowBox[{
                    "Indices", " ", "shifted", " ", "by", " ", "5", " ", 
                    "because", " ", "of", " ", "the", " ", "5", " ", "fixed", 
                    " ", "bodies", " ", 
                    RowBox[{"(", 
                    RowBox[{"floor", "+", 
                    RowBox[{"4", " ", "walls"}]}], ")"}]}], "*)"}], 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"quatToMatrix", "[", 
                    RowBox[{"bodies", "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{"5", "+", "i"}], ",", 
                    RowBox[{"5", ";;", "8"}]}], "]"}], "]"}], "]"}], ",", 
                    RowBox[{"bodies", "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{"5", "+", "i"}], ",", 
                    RowBox[{"2", ";;", "4"}]}], "]"}], "]"}]}], "}"}]}], 
                   "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", "3"}], "}"}]}], "]"}]}], "}"}]}], "}"}], 
            ",", 
            RowBox[{"PlotRange", "->", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "12"}], ",", "12"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "12"}], ",", "12"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1"}], ",", "15"}], "}"}]}], "}"}]}], ",", 
            RowBox[{"Boxed", "->", "False"}], ",", 
            RowBox[{"Lighting", "->", "\"\<Standard\>\""}], ",", 
            RowBox[{"ImageSize", "->", "Large"}], ",", 
            RowBox[{"Background", "->", 
             RowBox[{"GrayLevel", "[", "0.02", "]"}]}], ",", 
            RowBox[{"ViewPoint", "->", "Front"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"RapierWorldStep", "[", 
          RowBox[{"worldId", ",", "1", ",", 
           RowBox[{"1", "/", "60."}]}], "]"}], ";", "\[IndentingNewLine]", 
         "frame"}], ",", "240"}], "]"}], "]"}]}]}], "]"}], "\n"}]], "Input",
