          RowBox[{"worldId", ",", 
           RowBox[{"RapierAddRigidBody", "[", 
            RowBox[{"worldId", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"RandomReal", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "5"}], ",", "5"}], "}"}], "]"}], ",", 
               RowBox[{"RandomReal", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "5"}], ",", "5"}], "}"}], "]"}], ",", 
               RowBox[{
                RowBox[{"1.0", "*", "i"}], "+", "3.0"}]}], "}"}], ",", 
             RowBox[{"initialQuats", "[", "i", "]"}], 
             ",", "\"\<Dynamic\>\""}], "]"}], ",", 
