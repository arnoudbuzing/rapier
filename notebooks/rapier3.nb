        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "0.1", ",", "5"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "2.", " ", "Create", " ", "10", " ", "Dynamic", " ", "Cuboids", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"edge", " ", "size", " ", "0.7"}], "->", 
         RowBox[{"half", "-", 
          RowBox[{"extents", " ", "0.35"}]}]}], ")"}]}], "*)"}], 
     RowBox[{"cuboidIds", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"initialQuats", "[", "i", "]"}], "=", 
          RowBox[{"Normalize", "[", 
