                  RowBox[{"Mod", "[", 
                   RowBox[{"i", ",", "25"}], "]"}], "/", "5"}], "]"}], "*", 
                "2.0"}], "-", "4.0"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"Floor", "[", 
                 RowBox[{"i", "/", "25"}], "]"}], "*", "3.0"}], "+", 
               "5.0"}]}], "}"}], ",", "initialQuat", ",", "\"\<Dynamic\>\""}],
            "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"0.5", ",", "0.5", ",", "0.5"}], "}"}], ",", "1.0"}], 
         "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "74"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"3.", " ", "Create", " ", "Large", " ", "Blue", " ", "Ball", " ", 
      RowBox[{"(", 
       RowBox[{"Radius", " ", "2.5"}], ")"}], " ", "above", " ", "the", " ", 
      "cubes"}], "*)"}], 
    RowBox[{"ballId", "=", 
