Cell[BoxData[
 RowBox[{
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "worldId", ",", "floorId", ",", "cuboidIds", ",", "bodies", ",", 
      RowBox[{"step", "=", "0"}], ",", "initialQuat", ",", "quatToMatrix", ",",
       "frame"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{"Helper", ":", 
      RowBox[{"Convert", " ", "Rapier", " ", 
       RowBox[{"{", 
        RowBox[{"qx", ",", "qy", ",", "qz", ",", "qw"}], "}"}], " ", "to", " ",
        "Rotation", " ", "Matrix"}]}], "*)"}], 
    RowBox[{
     RowBox[{
      RowBox[{"quatToMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"qx_", ",", "qy_", ",", "qz_", ",", "qw_"}], "}"}], "]"}], ":=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "-", 
           RowBox[{"2", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"qy", "^", "2"}], "+", 
              RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", " ", "qy"}], "-", 
             RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", " ", "qz"}], "+", 
             RowBox[{"qw", " ", "qy"}]}], ")"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", " ", "qy"}], "+", 
             RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
          RowBox[{"1", "-", 
           RowBox[{"2", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"qx", "^", "2"}], "+", 
              RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qy", " ", "qz"}], "-", 
             RowBox[{"qw", " ", "qx"}]}], ")"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", " ", "qz"}], "-", 
             RowBox[{"qw", " ", "qy"}]}], ")"}]}], ",", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qy", " ", "qz"}], "+", 
             RowBox[{"qw", " ", "qx"}]}], ")"}]}], ",", 
          RowBox[{"1", "-", 
           RowBox[{"2", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"qx", "^", "2"}], "+", 
              RowBox[{"qy", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"1.", " ", "Setup", " ", "Simulation"}], "*)"}], 
     RowBox[{"worldId", "=", 
      RowBox[{"RapierWorldCreate", "[", 
       RowBox[{"{", 
        RowBox[{"0.", ",", "0.", ",", 
         RowBox[{"-", "9.81"}]}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"(*", 
      RowBox[{"Fixed", " ", "floor"}], "*)"}], 
     RowBox[{"floorId", "=", 
      RowBox[{"RapierAddRigidBody", "[", 
       RowBox[{"worldId", ",", 
        RowBox[{"{", 
         RowBox[{"0.", ",", "0.", ",", 
          RowBox[{"-", "0.1"}]}], "}"}], ",", "\"\<Fixed\>\""}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", "floorId", ",", 
       RowBox[{"{", 
        RowBox[{"10.", ",", "10.", ",", "0.1"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Invisible", " ", "Barriers", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"X", "+"}], ",", 
         RowBox[{"X", "-"}], ",", 
         RowBox[{"Y", "+"}], ",", 
         RowBox[{"Y", "-"}]}], ")"}]}], "*)"}], 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"10.1", ",", "0", ",", "10"}], "}"}], 
         ",", "\"\<Fixed\>\""}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"0.1", ",", "10", ",", "10"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10.1"}], ",", "0", ",", "10"}], "}"}], 
         ",", "\"\<Fixed\>\""}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"0.1", ",", "10", ",", "10"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "10.1", ",", "10"}], "}"}], 
         ",", "\"\<Fixed\>\""}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "0.1", ",", "10"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"-", "10.1"}], ",", "10"}], "}"}], ",", "\"\<Fixed\>\""}], 
        "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "0.1", ",", "10"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "2.", " ", "Create", " ", "75", " ", "Dynamic", " ", "Cuboids", " ", 
       RowBox[{"(", 
        RowBox[{"3", " ", "layers", " ", "of", " ", "25"}], ")"}]}], "*)"}], 
     RowBox[{"cuboidIds", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"initialQuat", "=", 
          RowBox[{"Normalize", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}], "+", 
            RowBox[{"RandomReal", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.05"}], ",", "0.05"}], "}"}], ",", "4"}], 
             "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"RapierAddColliderCuboid", "[", 
          RowBox[{"worldId", ",", 
           RowBox[{"RapierAddRigidBody", "[", 
            RowBox[{"worldId", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Mod", "[", 
                  RowBox[{"i", ",", "5"}], "]"}], "*", "2.0"}], "-", "4.0"}], 
               ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"Floor", "[", 
                  RowBox[{
                   RowBox[{"Mod", "[", 
                    RowBox[{"i", ",", "25"}], "]"}], "/", "5"}], "]"}], "*", 
                 "2.0"}], "-", "4.0"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"Floor", "[", 
                  RowBox[{"i", "/", "25"}], "]"}], "*", "3.0"}], "+", 
                "5.0"}]}], "}"}], ",", "initialQuat", 
             ",", "\"\<Dynamic\>\""}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"0.5", ",", "0.5", ",", "0.5"}], "}"}], ",", "1.0"}], 
          "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "74"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"FrameListVideo", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"bodies", "=", 
          RowBox[{"RapierGetBodyPositions", "[", "worldId", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"frame", "=", 
          RowBox[{"Graphics3D", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"(*", 
              RowBox[{"Red", " ", "floor", " ", "visual"}], "*)"}], 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"Red", ",", 
                RowBox[{"Opacity", "[", "0.6", "]"}], ",", 
                RowBox[{"Specularity", "[", 
                 RowBox[{"White", ",", "10"}], "]"}], ",", 
                RowBox[{"Cuboid", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"-", "10"}], ",", 
                    RowBox[{"-", "10"}], ",", 
                    RowBox[{"-", "0.2"}]}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"10", ",", "10", ",", "0"}], "}"}]}], "]"}]}], 
               "}"}], ",", 
              RowBox[{"(*", 
               RowBox[{"75", " ", "White", " ", "cubes"}], "*)"}], 
              RowBox[{"{", 
               RowBox[{"White", ",", 
                RowBox[{"Table", "[", 
