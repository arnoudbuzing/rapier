      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "10.1", ",", "5"}], "}"}], ",", "\"\<Fixed\>\""}],
         "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"10", ",", "0.1", ",", "5"}], "}"}], ",", "1.0"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"RapierAddColliderCuboid", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
