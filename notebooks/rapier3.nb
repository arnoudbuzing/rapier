               RowBox[{"-", "0.05"}], ",", "0.05"}], "}"}], ",", "4"}], 
            "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"RapierAddColliderCuboid", "[", 
         RowBox[{"worldId", ",", 
          RowBox[{"RapierAddRigidBody", "[", 
           RowBox[{"worldId", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Mod", "[", 
                 RowBox[{"i", ",", "5"}], "]"}], "*", "2.0"}], "-", "4.0"}], ",", 
