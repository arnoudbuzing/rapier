      RowBox[{"{", 
       RowBox[{"0.1", ",", "10", ",", "10"}], "}"}], ",", "1.0"}], "]"}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"RapierAddColliderCuboid", "[", 
     RowBox[{"worldId", ",", 
      RowBox[{"RapierAddRigidBody", "[", 
       RowBox[{"worldId", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "10.1", ",", "10"}], "}"}], ",", "\"\<Fixed\>\""}],
        "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"10", ",", "0.1", ",", "10"}], "}"}], ",", "1.0"}], "]"}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"RapierAddColliderCuboid", "[", 
     RowBox[{"worldId", ",", 
      RowBox[{"RapierAddRigidBody", "[", 
       RowBox[{"worldId", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"-", "10.1"}], ",", "10"}], "}"}], ",", "\"\<Fixed\>\""}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"10", ",", "0.1", ",", "10"}], "}"}], ",", "1.0"}], "]"}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"2.", " ", "Create", " ", "75", " ", "Dynamic", " ", "Cuboids"}],
      "*)"}], 
    RowBox[{"cuboidIds", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"initialQuat", "=", 
         RowBox[{"Normalize", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}], "+", 
