Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Simulate", " ", "4", " ", "seconds"}], ",", 
    RowBox[{"collecting", " ", "frames", " ", "at", " ", "60", " ", "FPS"}]}],
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dt", "=", 
     RowBox[{"1.0", "/", "60.0"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"totalFrames", "=", "240"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"frames", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"model", "=", 
        RowBox[{"PhysicsModelIterate", "[", 
         RowBox[{"model", ",", "1", ",", "dt"}], "]"}]}], ";", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"frames", ",", "model"}], "]"}], ";"}], ",", 
      RowBox[{"{", "totalFrames", "}"}]}], "]"}], ";"}], "\[IndentingNewLine]",
    "model"}]}]], "Input",
 CellChangeTimes->{{3.984824753891632*^9, 3.984824783867713*^9}, {
