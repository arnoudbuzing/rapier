Cell["Create a model with a large number of cones:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9852052271477003`*^9, 3.985205238222639*^9}},
 CellID->418470121,ExpressionUUID->"2314391a-b51f-4ce9-830b-45136fac53bc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"model", "=", 
   RowBox[{"CreatePhysicsModel", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PhysicsBoundaryBox", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "4"}], ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "4", ",", "6"}], "}"}]}], "}"}], ",", 
         RowBox[{"\"\<Thickness\>\"", "->", "1"}]}], "]"}], ",", 
       RowBox[{"FixedBody", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"HatchShading", "[", 
           RowBox[{".6", ",", "Blue"}], "]"}], ",", 
          RowBox[{"Cuboid", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "4"}], ",", 
              RowBox[{"-", "4"}], ",", 
              RowBox[{"-", "1"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"4", ",", "4", ",", "0"}], "}"}]}], "]"}]}], "}"}], 
        "]"}], ",", 
       RowBox[{"FixedBody", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"HatchShading", "[", 
           RowBox[{".6", ",", "Orange"}], "]"}], ",", 
          RowBox[{"Cylinder", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "2"}], ",", 
                RowBox[{"-", "2"}], ",", "0.5"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"2", ",", "2", ",", "0.5"}], "}"}]}], "}"}], ",", 
            "1.0"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"DynamicBody", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"MaterialShading", "[", "\"\<Copper\>\"", "]"}], ",", 
            RowBox[{"Cone", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"i", ",", "j", ",", "4"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"i", "+", 
                   RowBox[{"RandomReal", "[", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0.1"}], "}"}], "]"}]}], ",", 
                  RowBox[{"j", "+", 
                   RowBox[{"RandomReal", "[", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0.1"}], "}"}], "]"}]}], ",", "5"}], 
                 "}"}]}], "}"}], ",", "0.25"}], "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"-", "3"}], ",", "3", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"-", "3"}], ",", "3", ",", "1"}], "}"}]}], "]"}]}], "}"}], 
     ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["2", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["720", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      "Gravity" -> {0, 0, -9.81}, 
       "Graphics3DOptions" -> {
        Background -> Black, Axes -> False, Boxed -> False, ViewPoint -> 
         Front, ImageSize -> Large}],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985205198642555*^9, 3.985205212473591*^9}, 
   3.985205246867371*^9},
 CellLabel->"In[112]:=",
 CellID->47546278,ExpressionUUID->"5ae69bdb-53db-4793-87f3-e8c834510718"],

Cell["Evolve the model for 300 steps with time step 1/60:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9852040850185537`*^9, 3.985204105161668*^9}},
 CellID->302886189,ExpressionUUID->"4856b36e-f787-4d5b-9158-a0e3fcdacd1e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"frames", "=", 
   RowBox[{"PhysicsModelEvolve", "[", 
    RowBox[{"model", ",", "300", ",", 
     RowBox[{"1.0", "/", "60.0"}]}], "]"}]}], ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985205198642555*^9, 3.985205212473591*^9}, {
  3.985205246867371*^9, 3.985205262967189*^9}},
 CellLabel->"In[113]:=",
 CellID->1024614696,ExpressionUUID->"70068af1-527e-49e0-96b4-6d8c3b9d6e23"],

