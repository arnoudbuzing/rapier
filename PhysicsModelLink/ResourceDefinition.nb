Cell["Create a collection of \"dominoes\":", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.985204660035091*^9, 3.985204686741102*^9}},
 CellID->1197853575,ExpressionUUID->"254a7e90-e094-4124-a380-28942343789b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dominoes", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"DynamicBody", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"MaterialShading", "[", "\"\<Copper\>\"", "]"}], ",", 
        RowBox[{"Cuboid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "-", "0.08"}], ",", 
            RowBox[{"-", "0.3"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "+", "0.08"}], ",", "0.3", ",", "0.8"}], "}"}]}], 
         "]"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3", ",", "0.6"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985204622964322*^9, 3.9852046253892927`*^9}},
 CellLabel->"In[100]:=",
 CellID->1304413954,ExpressionUUID->"b2ec4ba9-2521-4d20-bcdf-d10b56e1df6d"],

Cell["Create a ball that will push over the dominoes:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9852046911742487`*^9, 3.985204704261531*^9}},
 CellID->923275861,ExpressionUUID->"5541e44a-7ab4-4871-8e50-2feee84d399a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ball", "=", 
   RowBox[{"DynamicBody", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"MaterialShading", "[", "\"\<Gold\>\"", "]"}], ",", 
       RowBox[{"Sphere", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "3.8"}], ",", "0", ",", "0.4"}], "}"}], ",", "0.35"}],
         "]"}]}], "}"}], ",", 
     RowBox[{"\"\<Density\>\"", "->", "5.0"}], ",", 
     RowBox[{"\"\<Velocity\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"3", ",", "0", ",", "0"}], "}"}]}]}], "]"}]}], ";"}]], "Input",
 
 TaggingRules->{},
 CellChangeTimes->{{3.985204622964322*^9, 3.985204631501656*^9}, {
  3.985204721759603*^9, 3.985204722366427*^9}},
 CellLabel->"In[101]:=",
 CellID->1772256302,ExpressionUUID->"0ca627c2-8cb6-43f9-8674-78f17f7a06bb"],

Cell["Create the model from the ball and dominoes:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9852047095903397`*^9, 3.98520471956244*^9}},
 CellID->1421090451,ExpressionUUID->"451acd42-3cf2-414c-9fad-75234c002239"],

Cell[BoxData[
 RowBox[{
  RowBox[{"model", "=", 
   RowBox[{"CreatePhysicsModel", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PhysicsBoundaryBox", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "4"}], ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "4", ",", "6"}], "}"}]}], "}"}], ",", 
         RowBox[{"\"\<Thickness\>\"", "->", "1"}]}], "]"}], ",", 
       RowBox[{"FixedBody", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"HatchShading", "[", 
           RowBox[{".6", ",", "Gray"}], "]"}], ",", 
          RowBox[{"Cuboid", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "4"}], ",", 
              RowBox[{"-", "4"}], ",", 
              RowBox[{"-", "1"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"4", ",", "4", ",", "0"}], "}"}]}], "]"}]}], "}"}], 
        "]"}], ",", "dominoes", ",", "ball"}], "}"}], ",", 
     RowBox[{"\"\<Gravity\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", 
        RowBox[{"-", "9.81"}]}], "}"}]}], ",", 
     RowBox[{"\"\<Graphics3DOptions\>\"", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Background", "->", "Black"}], ",", 
        RowBox[{"Axes", "->", "False"}], ",", 
        RowBox[{"Boxed", "->", "False"}], ",", 
        RowBox[{"ViewPoint", "->", "Front"}], ",", 
        RowBox[{"ImageSize", "->", "Large"}]}], "}"}]}]}], "]"}]}], 
  ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985204622964322*^9, 3.985204633422715*^9}, {
  3.9852047271076183`*^9, 3.9852047274741697`*^9}},
 CellLabel->"In[102]:=",
 CellID->364826354,ExpressionUUID->"ba241d42-ba76-4f3d-b7a3-9eb2006f0d09"],

Cell["Evolve the model for 300 steps with time step 1/60:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9852040850185537`*^9, 3.985204105161668*^9}},
 CellID->65107814,ExpressionUUID->"1d9b6504-d6be-4eab-9951-8025f836f427"],

Cell[BoxData[
 RowBox[{
  RowBox[{"frames", "=", 
   RowBox[{"PhysicsModelEvolve", "[", 
    RowBox[{"model", ",", "300", ",", 
     RowBox[{"1.0", "/", "60.0"}]}], "]"}]}], ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985204622964322*^9, 3.985204634965312*^9}},
 CellLabel->"In[103]:=",
 CellID->1622926604,ExpressionUUID->"d431aede-31f6-46e3-961e-54710961be12"],

Cell["Generate a video from the frames:", "Text",
