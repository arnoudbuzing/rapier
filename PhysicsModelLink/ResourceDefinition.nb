Cell[CellGroupData[{

Cell[TextData[{
 "Basic Description",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"LongDescription", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
        "Give a short paragraph explaining your paclet. This is the first \
text that users will see when visiting the main landing page of your paclet.",
          "MoreInfoText"], Background -> GrayLevel[0.95], FrameMargins -> 20, 
        FrameStyle -> GrayLevel[0.9], RoundingRadius -> 5, ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoLongDescription"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
    "MoreInfoOpenerButtonTemplate"]}, Dynamic[
    CurrentValue[
     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "8d9cb522-c25b-43a0-99e1-a21834420bf7"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "LongDescription"},
 DefaultNewCellStyle->"Text",
 CellTags->{"Basic Description", "LongDescription", "TemplateCellGroup"},
 CellID->97826971,ExpressionUUID->"caca2fbd-7513-453f-b5e5-1bff9392b6f6"],

Cell["\<\
PhysicsModelLink provides a high-level interface for creating and simulating \
rigid body physics in the Wolfram Language. It lets you wrap standard 3D \
graphics primitives\[LongDash]such as spheres, cuboids, cylinders, cones, and \
capsules\[LongDash]as dynamic or fixed bodies, run time-stepped physics \
simulations with gravity and collisions, and visualize or animate the results \
as Graphics3D scenes.\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{3.985006889218649*^9},
 CellTags->"DefaultContent",
 CellID->312061637,ExpressionUUID->"1a2b2116-1af7-4f2c-986d-bfc203c0ddb4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Details",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"Details", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
        "Details may include a long description of the resource's contents, \
history, methodology or other relevant information. Give references here if \
they are directly relevant to the resource. The details will appear above the \
examples on the webpage for the resource.", "MoreInfoText"], Background -> 
        GrayLevel[0.95], FrameMargins -> 20, FrameStyle -> GrayLevel[0.9], 
        RoundingRadius -> 5, ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoDetails"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
    "MoreInfoOpenerButtonTemplate"]}, Dynamic[
    CurrentValue[
     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "0ab3db69-dc02-4fe2-9ed6-1e92dfa90e2d"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "Details"},
 DefaultNewCellStyle->"Notes",
 CellTags->{"Details", "TemplateCellGroup"},
 CellID->280804237,ExpressionUUID->"90fd0780-279d-4a5a-a8d4-00d4c08c1981"],

Cell[TextData[{
 "PhysicsModelLink provides rigid body physics simulation for standard \
Wolfram Language 3D graphics primitives including ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Sphere", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Sphere",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ccf947d9-37b0-43ac-a3ff-61a7b1997346"],
 ", ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Cuboid", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Cuboid",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0d3d63f7-2f0a-4421-b24d-2ed6b738dcd5"],
 ", ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Cylinder", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Cylinder",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0e090d6e-e3c0-456c-9db6-78032fac09f3"],
 ", ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Cone", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Cone",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "85c87801-d2b4-4879-91f2-f3c02d9168b0"],
 ", and ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["CapsuleShape", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/CapsuleShape",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1090b742-c5b1-4cbd-b65f-5456c6174f2b"],
 "."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.985007098664819*^9}},
 CellTags->"DefaultContent",
 CellID->741278932,ExpressionUUID->"167ee410-ed24-4a9a-9d56-9c389e922706"],

Cell[TextData[{
 "The underlying physics engine is the Rapier 3D physics library (Rust crate ",
 ButtonBox["rapier3d",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://rapier.rs/"], None}],
 "), accessed via ",
 ButtonBox["LibraryLink",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/guide/LibraryLink.html"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/guide/LibraryLink.html"],
 "."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.9850071112448807`*^9}, 
   3.9850071529236403`*^9, {3.985007461950696*^9, 3.985007461950851*^9}},
 CellTags->"DefaultContent",
 CellID->1886878278,ExpressionUUID->"d6a1f1a6-06e3-4d3d-afe5-ce123348c297"],

Cell["\<\
Simulations are stateful: CreatePhysicsModel allocates a persistent physics \
world in memory, and DestroyPhysicsModel frees it. Each world is identified \
by a unique integer handle.\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.985007109509831*^9}, {
  3.985007428054206*^9, 3.9850074435358267`*^9}, {3.985007473656295*^9, 
  3.985007477116233*^9}},
 CellTags->"DefaultContent",
 CellID->1253032187,ExpressionUUID->"8e643ca6-0a48-400d-816c-44f4d6ed6270"],

Cell["\<\
Bodies are classified as either DynamicBody (affected by gravity and \
collisions) or FixedBody (immovable obstacles/floors).\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.985007109509831*^9}, {
  3.985007428054206*^9, 3.9850074435358267`*^9}, {3.985007473656295*^9, 
  3.9850074821562843`*^9}},
 CellTags->"DefaultContent",
 CellID->586570958,ExpressionUUID->"ad59b546-8fd3-4c69-8f22-833d2bea8024"],

Cell["\<\
Each body has physical material properties that can be set via options: \
\"Density\" (default 1.0), \"Restitution\" (bounciness, default 0.5), and \
\"Friction\" (default 0.5).\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.985007109509831*^9}, {
  3.985007428054206*^9, 3.9850074435358267`*^9}, {3.985007473656295*^9, 
  3.985007488367086*^9}},
 CellTags->"DefaultContent",
 CellID->1548151376,ExpressionUUID->"635c89a0-4c28-41d8-a8de-70a86834594c"],

Cell["\<\
Initial velocities can be assigned to dynamic bodies using the \"Velocity\" \
option.\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.985007109509831*^9}, {
  3.985007428054206*^9, 3.9850074435358267`*^9}, {3.985007473656295*^9, 
  3.985007492561038*^9}},
 CellTags->"DefaultContent",
 CellID->699754555,ExpressionUUID->"95e267ec-b4c2-4600-a786-e9c9b4f4c5e1"],

Cell[TextData[{
 "Body orientations are tracked internally as quaternions and converted \
to/from 3\[Times]3 rotation matrices for compatibility with ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["GeometricTransformation", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/GeometricTransformation",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5f4ef856-4bb9-4f96-87d5-f67e5a2f022d"],
 "."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.985007109509831*^9}, {
  3.985007428054206*^9, 3.9850074435358267`*^9}, {3.985007473656295*^9, 
  3.9850074957809687`*^9}},
 CellTags->"DefaultContent",
 CellID->2122180060,ExpressionUUID->"1e8400f8-7818-4675-be6d-006691a0aaa4"],

Cell[TextData[{
 "Time evolution is performed with PhysicsModelIterate, which steps the \
simulation by a given number of substeps at a fixed time increment ",
 Cell[BoxData[
  StyleBox["dt", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4d62e44-b3e5-4b9c-81eb-e16016ad7d34"],
 ". Smaller ",
 Cell[BoxData[
  StyleBox["dt", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1736b71c-0460-4949-9495-5416e06195b5"],
 " values yield more accurate results."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.985007109509831*^9}, {
  3.985007428054206*^9, 3.9850074435358267`*^9}, {3.985007473656295*^9, 
  3.9850075133038607`*^9}},
 CellTags->"DefaultContent",
 CellID->989421178,ExpressionUUID->"1c642a9a-43da-4942-a926-980594a3ac9f"],

Cell["\<\
PhysicsModelEvolve is a convenience function that collects a sequence of \
PhysicsModelObject frames for animation.\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.985007074001012*^9, 3.985007109509831*^9}, {
  3.985007428054206*^9, 3.9850074435358267`*^9}, {3.985007473656295*^9, 
  3.9850075194202147`*^9}},
 CellTags->"DefaultContent",
 CellID->2124461165,ExpressionUUID->"9e8ef58b-afc3-400b-ac5f-bcff222294b3"],

Cell[TextData[{
 "PhysicsModelPlot renders the current state as a ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
