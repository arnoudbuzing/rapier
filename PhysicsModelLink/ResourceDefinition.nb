        RowBox[{
         RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "0.5"}], ",", "6"}], "}"}]}], "}"}]}]}]}], 
  "]"}]], "Input",
