Cell["Create a simple model with a falling ball and a fixed floor:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.985008442594562*^9, 3.9850084493698797`*^9}, {
  3.985203395625454*^9, 3.9852034168509083`*^9}},
 CellTags->"DefaultContent",
 CellID->489008670,ExpressionUUID->"9baa55ba-2af0-497f-9df7-5058a13bd8ee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"PhysicsBoundaryBox", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "4"}], ",", 
            RowBox[{"-", "4"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"4", ",", "4", ",", "6"}], "}"}]}], "}"}], ",", 
        RowBox[{"\"\<Thickness\>\"", "->", "1"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"FixedBody", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"HatchShading", "[", 
          RowBox[{".6", ",", "Blue"}], "]"}], ",", 
         RowBox[{"Cuboid", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "4", ",", "0"}], "}"}]}], "]"}]}], "}"}], "]"}],
       ",", "\[IndentingNewLine]", 
      RowBox[{"DynamicBody", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"MaterialShading", "[", "\"\<Gold\>\"", "]"}], ",", 
         RowBox[{"Sphere", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", "5"}], "}"}], ",", "0.6"}], "]"}]}], 
        "}"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", "SequenceIcon", 
        GridBox[{{
           RowBox[{
             TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["Sequence", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["2", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["720", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     Sequence[
     "Gravity" -> {0, 0, -9.81}, 
      "Graphics3DOptions" -> {
       Background -> Black, Axes -> False, Boxed -> False, ViewPoint -> Front,
         ImageSize -> Large}],
     SelectWithContents->True,
     Selectable->False]}], "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985008421298802*^9, 3.985008440335432*^9}, {
  3.985008690084529*^9, 3.9850086910490417`*^9}, {3.985203351318245*^9, 
  3.98520338558393*^9}},
 CellTags->"DefaultContent",
 CellLabel->"In[87]:=",
 CellID->346709167,ExpressionUUID->"fd65c967-7359-4db2-a86a-be796572441d"],

